# ── Database (Neon PostgreSQL) ─────────────────────────────────────────────
# Get from: https://console.neon.tech/
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Clerk Authentication ──────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com/ → API Keys
CLERK_PUBLISHABLE_KEY=pk_live_xxxxx
CLERK_SECRET_KEY=sk_live_xxxxx

# ── Frontend (Vite bakes these in at build time) ──────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxxxx
# Optional: only needed if using Clerk proxy
VITE_CLERK_PROXY_URL=

# ── Server ────────────────────────────────────────────────────────────────
PORT=10000
NODE_ENV=production

# ── Stripe (optional — leave empty to disable paywall) ───────────────────
# When set, stripe-replit-sync initializes. Leave empty to skip.
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx

# ── Owner bypass (comma-separated) ────────────────────────────────────────
# Users matching either list skip subscription checks and the AI monthly
# budget hard cap.
OWNER_USER_IDS=
OWNER_EMAILS=

# ── AI budget & usage tracking ────────────────────────────────────────────
# Total monthly AI spend, in dollars, before the hard cap kicks in.
AI_MONTHLY_DOLLAR_LIMIT=25
# Percent of the monthly limit at which a warning header/log kicks in.
AI_SOFT_LIMIT_PERCENT=80
# Percent of the monthly limit at which AI calls are blocked (owner excepted).
AI_HARD_LIMIT_PERCENT=100
# IANA timezone used to determine "today" and "this month" for AI limits.
AI_LIMIT_TIMEZONE=America/Chicago
# Optional: override per-model $ price per 1M tokens without a code change.
# Unknown models fall back to the gpt-5.4 rate so spend is never under-counted.
# AI_MODEL_PRICES={"gpt-4o-mini":{"in":0.15,"out":0.60},"gpt-5.4":{"in":2.50,"out":15.00}}
